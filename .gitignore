# =========================
# SpikeAdapt-SC .gitignore
# =========================

# Data & Datasets
data/
FoodSeg103/
CCNet/
*.zip

# Model checkpoints (large binary files)
snapshots_*/
*.pth

# Logs
*.log
*.txt
nohup.out

# Python bytecode
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/
dist/
build/
.venv/

# Build artifacts
inplace_abn/
inplace_abn.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Gemini agent
.gemini/

# Eval intermediate outputs (not in eval/seed_results/)
eval_results/
results/

# Shell launch scripts (dev-only)
*.sh

# Jupyter notebooks (use archive/ for old ones)
*.ipynb

# LaTeX source and build artifacts
*.tex
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.synctex*
paper/*.bak

# Archive directory (kept locally, not pushed)
# archive/
